# === Raw & large data files — excluded from version control ===
2_data/raw/*
!2_data/raw/.gitkeep

# === Python artifacts ===
__pycache__/
*.py[cod]
*.egg-info/
.ipynb_checkpoints/

# === Virtual environments ===
venv/
.venv/
env/

# === Trained model files (too large for Git) ===
3_models/outputs/*.pkl
3_models/outputs/*.joblib

# === Secrets & credentials ===
.env
*.key
*.pem
credentials.json

# === macOS system files ===
.DS_Store

# === IDE & editor config ===
.vscode/
.idea/

# === LaTeX build artifacts ===
report/*.aux
report/*.log
report/*.out
report/*.toc
report/*.pdf
